# --- Runtime data: ignore everything in data/ by default, allowlist config ---
# Prevents accidentally committing bets.csv, closing lines, bet cards,
# model predictions, notifications, or any new data file added in the future.
data/*
!data/alerts_config.json
!data/.gitkeep
