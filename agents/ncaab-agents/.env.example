ODDS_API_KEY=your_odds_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
WEATHER_API_KEY=your_openweathermap_api_key_here

# Shared live-odds feed (optional). Point this at the betting-site backend to
# reuse its live-odds cache instead of spending your own Odds API credits.
# ODDS_FEED_SPORT is the backend's app sport key (NOT the Odds API key); leave
# it empty until the backend registers college basketball, then set it (e.g.
# "ncaab"). Any feed failure falls back to the Odds API automatically.
ODDS_FEED_BASE_URL=http://127.0.0.1:8000
ODDS_FEED_SPORT=
ODDS_FEED_TTL_SECONDS=20
# Ignore the feed (fall back to the Odds API) if the backend's odds are older
# than this many seconds. Keep above the backend poll interval; 0 disables.
ODDS_FEED_MAX_STALE_SECONDS=900
