ODDS_API_KEY=your_odds_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
WEATHER_API_KEY=your_openweathermap_api_key_here

# Shared live-odds feed (optional). Point this at the betting-site backend to
# reuse its live-odds cache instead of spending your own Odds API credits on
# games the backend is already polling. Leave ODDS_FEED_BASE_URL empty to keep
# hitting The Odds API directly. Any feed failure falls back to the API
# automatically; historical odds always use the API.
ODDS_FEED_BASE_URL=http://127.0.0.1:8000
# Backend app sport key (NOT the Odds API key). MLB lives under "mlb".
ODDS_FEED_SPORT=mlb
# Seconds to memoize the feed response within a pipeline run.
ODDS_FEED_TTL_SECONDS=20
