# Copy your Odds API key from the baseball-agents .env
ODDS_API_KEY=your_key_here
# Path where baseball-agents writes daily bet cards
BET_CARD_DIR=/Users/mikeborucki/personal_workspace/agents/baseball-agents/data
# Path to bets.csv (for track records)
BETS_CSV=/Users/mikeborucki/personal_workspace/agents/baseball-agents/data/bets.csv
# Poll intervals (seconds)
ODDS_POLL_INTERVAL=30
# Simultaneous in-flight Odds API requests within one tier run. The
# per-event tiers (alternates, periods, player_props) fan out one call
# per event. Default 4 stays under the per-second freq limit on most
# plan tiers; the client retries 429s with backoff so the occasional
# spike doesn't drop rows. Raise if your plan tier publishes a higher
# req/sec cap. Set to 1 for the pre-2026-05-12 serial behavior.
ODDS_API_CONCURRENCY=4
# API budget floor — below this, skip per-event enrichment
API_BUDGET_FLOOR=100
# Backend bind
HOST=127.0.0.1
PORT=8000
# coral33.com credentials (used as both customerID and client_id in auth)
CORAL33_CUSTOMER_ID=your_customer_id_here
CORAL33_PASSWORD=your_password_here
# Set to false to disable the coral33 scraper tier
CORAL33_ENABLED=true
# Coral33 polling cadence — base interval and ± jitter, in seconds.
# Default is 60s ±15s (45–75s actual). Lower = fresher prices but more
# captcha-trigger risk. Roll back to 240/60 if `/api/coral33/status` shows
# captcha_backoff_remaining_s > 0 frequently.
CORAL33_CYCLE_SECONDS=60
CORAL33_CYCLE_JITTER=15

# Kalshi authenticated API access (optional). Unauthenticated reads work
# without these; setting both unlocks higher rate limits, WebSocket auth,
# and portfolio / order endpoints.
#
# 1. Get your API key from https://kalshi.com/account/profile (API
#    Access section). Generate a new key — you'll get a UUID and an
#    RSA private key.
# 2. Save the private key as a .pem file with chmod 600. The
#    server/.secrets/ dir is gitignored.
# 3. Set both vars below.
KALSHI_API_KEY=your-key-uuid-here
KALSHI_PRIVATE_KEY_PATH=server/.secrets/kalshi-private.pem

# ── Odds time-series & cold storage ──────────────────────────────────
# The odds_history table keeps a hot window of recent price movement for
# fast API reads. Rows older than this roll off to the cold Parquet lake.
ODDS_HISTORY_HOT_DAYS=90
# When true, aged-out rows are exported to a compressed (zstd) Parquet
# dataset (retained indefinitely) BEFORE being purged from hot. Set false
# to fall back to a plain destructive purge (data is NOT retained).
ODDS_ARCHIVE_ENABLED=true
# Where the Parquet lake lives (partitioned by sport_key / year_month).
# Defaults to server/archive. Gitignored; back it up / ship it out-of-band.
ODDS_ARCHIVE_DIR=server/archive
