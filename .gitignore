# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
*.egg-info/

# Node
node_modules/
.next/
.turbo/
out/

# Env
.env
.env.local
*.local

# Secrets — RSA private keys etc. Never commit under any circumstance.
server/.secrets/
*.pem
*.key

# Superpowers scratch
.superpowers/

# SQLite cache
server/cache.db
server/cache.db-journal
server/cache.snapshot.db
server/cache.snapshot.db-journal
server/cache_snapshot.db

# Runtime mode state (toggled by the cache-mode UI; per-machine)
server/cache_mode.json

# Persisted wager log (one-time Coral33 backfill, contains bet detail)
server/data/

# OS
.DS_Store

# Playwright MCP screenshots / snapshots (audit artifacts, local-only)
.playwright-mcp/
# UI audit artifacts written to repo root by Playwright screenshots / snapshots
/*.png
/*-snapshot.yml

# Logs (defensive — agent scrapers write coral_scraper.log etc. which can
# accumulate request URLs, timing data, and potentially auth-relevant noise)
*.log

# Claude Code / agent worktrees — heavy, redundant clones, never source-of-truth
.claude/
**/.worktrees/

# Agents monorepo — these patterns apply to every agents/<name>/ subdir.
# .env files are the main concern; .env.example placeholders are fine.
agents/**/.env
agents/**/.env.local
