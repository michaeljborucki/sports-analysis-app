{
  "openapi": "3.1.0",
  "info": {
    "title": "Betting Site API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FetcherStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/odds/{sport}": {
      "get": {
        "summary": "Get Odds",
        "operationId": "get_odds_api_odds__sport__get",
        "parameters": [
          {
            "name": "sport",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Sport"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OddsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/props/{sport}": {
      "get": {
        "summary": "Get Props",
        "operationId": "get_props_api_props__sport__get",
        "parameters": [
          {
            "name": "sport",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Sport"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OddsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/picks/{sport}": {
      "get": {
        "summary": "Get Picks",
        "operationId": "get_picks_api_picks__sport__get",
        "parameters": [
          {
            "name": "sport",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Sport"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PicksResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/fetcher/start": {
      "post": {
        "summary": "Start",
        "operationId": "start_api_fetcher_start_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FetcherControlResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/fetcher/stop": {
      "post": {
        "summary": "Stop",
        "operationId": "stop_api_fetcher_stop_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FetcherControlResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/refresh/{event_id}": {
      "post": {
        "summary": "Refresh",
        "operationId": "refresh_api_refresh__event_id__post",
        "parameters": [
          {
            "name": "event_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Event Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FetcherControlResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/sports": {
      "get": {
        "summary": "Get Sports",
        "operationId": "get_sports_api_sports_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SportsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/arbitrage": {
      "get": {
        "summary": "Get Arbs",
        "description": "Scan the cache for two-way arbitrage opportunities.\n\n`books` is an optional comma-separated allowlist \u2014 only prices from\nthese bookmaker keys are considered. Empty = all books in the cache.",
        "operationId": "get_arbs_api_arbitrage_get",
        "parameters": [
          {
            "name": "books",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "Books"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArbResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ArbOpportunity": {
        "properties": {
          "sport_key": {
            "type": "string",
            "title": "Sport Key"
          },
          "event_id": {
            "type": "string",
            "title": "Event Id"
          },
          "home_team": {
            "type": "string",
            "title": "Home Team"
          },
          "away_team": {
            "type": "string",
            "title": "Away Team"
          },
          "commence_time": {
            "type": "string",
            "format": "date-time",
            "title": "Commence Time"
          },
          "market_kind": {
            "type": "string",
            "enum": [
              "h2h",
              "spreads",
              "totals"
            ],
            "title": "Market Kind"
          },
          "point": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Point"
          },
          "roi_pct": {
            "type": "number",
            "title": "Roi Pct"
          },
          "sides": {
            "items": {
              "$ref": "#/components/schemas/ArbSide"
            },
            "type": "array",
            "title": "Sides"
          }
        },
        "type": "object",
        "required": [
          "sport_key",
          "event_id",
          "home_team",
          "away_team",
          "commence_time",
          "market_kind",
          "roi_pct",
          "sides"
        ],
        "title": "ArbOpportunity"
      },
      "ArbResponse": {
        "properties": {
          "opportunities": {
            "items": {
              "$ref": "#/components/schemas/ArbOpportunity"
            },
            "type": "array",
            "title": "Opportunities"
          },
          "scanned_at": {
            "type": "string",
            "format": "date-time",
            "title": "Scanned At"
          },
          "book_count": {
            "type": "integer",
            "title": "Book Count"
          }
        },
        "type": "object",
        "required": [
          "opportunities",
          "scanned_at",
          "book_count"
        ],
        "title": "ArbResponse"
      },
      "ArbSide": {
        "properties": {
          "outcome_name": {
            "type": "string",
            "title": "Outcome Name"
          },
          "book": {
            "type": "string",
            "title": "Book"
          },
          "price_american": {
            "type": "integer",
            "title": "Price American"
          },
          "point": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Point"
          },
          "stake_pct": {
            "type": "number",
            "title": "Stake Pct"
          }
        },
        "type": "object",
        "required": [
          "outcome_name",
          "book",
          "price_american",
          "stake_pct"
        ],
        "title": "ArbSide"
      },
      "BookPrice": {
        "properties": {
          "bookmaker_key": {
            "type": "string",
            "title": "Bookmaker Key"
          },
          "price_american": {
            "type": "integer",
            "title": "Price American"
          },
          "point": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Point"
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "title": "Fetched At"
          }
        },
        "type": "object",
        "required": [
          "bookmaker_key",
          "price_american",
          "fetched_at"
        ],
        "title": "BookPrice"
      },
      "FetcherControlResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "tiers": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tiers"
          },
          "retry_after_seconds": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Retry After Seconds"
          },
          "event_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Event Id"
          },
          "polled": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Polled"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "FetcherControlResponse"
      },
      "FetcherStatus": {
        "properties": {
          "last_fetch_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Fetch At"
          },
          "requests_used": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Requests Used"
          },
          "requests_remaining": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Requests Remaining"
          },
          "last_error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Error"
          },
          "fetcher_running": {
            "type": "boolean",
            "title": "Fetcher Running",
            "default": false
          },
          "enabled_tiers": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Enabled Tiers"
          }
        },
        "type": "object",
        "title": "FetcherStatus"
      },
      "Game": {
        "properties": {
          "event_id": {
            "type": "string",
            "title": "Event Id"
          },
          "sport_key": {
            "type": "string",
            "title": "Sport Key",
            "default": "mlb"
          },
          "home_team": {
            "type": "string",
            "title": "Home Team"
          },
          "away_team": {
            "type": "string",
            "title": "Away Team"
          },
          "commence_time": {
            "type": "string",
            "format": "date-time",
            "title": "Commence Time"
          },
          "is_live": {
            "type": "boolean",
            "title": "Is Live",
            "default": false
          },
          "markets": {
            "items": {
              "$ref": "#/components/schemas/Market"
            },
            "type": "array",
            "title": "Markets"
          },
          "stale_seconds": {
            "type": "integer",
            "title": "Stale Seconds",
            "default": 0
