        "type": "object",
        "required": [
          "event_id",
          "home_team",
          "away_team",
          "commence_time",
          "markets"
        ],
        "title": "Game"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Market": {
        "properties": {
          "market_key": {
            "type": "string",
            "title": "Market Key"
          },
          "outcomes": {
            "items": {
              "$ref": "#/components/schemas/MarketOutcome"
            },
            "type": "array",
            "title": "Outcomes"
          }
        },
        "type": "object",
        "required": [
          "market_key",
          "outcomes"
        ],
        "title": "Market"
      },
      "MarketGroupModel": {
        "properties": {
          "label": {
            "type": "string",
            "title": "Label"
          },
          "main_key": {
            "type": "string",
            "title": "Main Key"
          },
          "alt_key": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
