        },
        "type": "object",
        "required": [
          "label",
          "main_key"
        ],
        "title": "MarketGroupModel"
      },
      "MarketOutcome": {
        "properties": {
          "outcome_name": {
            "type": "string",
            "title": "Outcome Name"
          },
          "prices": {
            "items": {
              "$ref": "#/components/schemas/BookPrice"
            },
            "type": "array",
            "title": "Prices"
          },
          "best_price": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/BookPrice"
              },
              {
                "type": "null"
              }
            ]
          },
          "consensus_price_american": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Consensus Price American"
          }
        },
        "type": "object",
        "required": [
          "outcome_name",
          "prices"
        ],
        "title": "MarketOutcome"
      },
      "OddsResponse": {
        "properties": {
          "games": {
            "items": {
              "$ref": "#/components/schemas/Game"
            },
            "type": "array",
            "title": "Games"
          },
          "stale_seconds": {
            "type": "integer",
            "title": "Stale Seconds"
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "title": "Fetched At"
          }
        },
        "type": "object",
        "required": [
          "games",
          "stale_seconds",
          "fetched_at"
        ],
        "title": "OddsResponse"
      },
      "Pick": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "tier": {
            "$ref": "#/components/schemas/PickTier"
          },
          "game_label": {
            "type": "string",
            "title": "Game Label"
          },
          "market_label": {
            "type": "string",
            "title": "Market Label"
          },
          "pick_side": {
            "type": "string",
            "title": "Pick Side"
          },
          "odds_american": {
            "type": "integer",
            "title": "Odds American"
          },
          "best_book": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Best Book"
          },
          "stake_units": {
            "type": "number",
            "title": "Stake Units"
          },
          "probability_pct": {
            "type": "number",
            "title": "Probability Pct"
          },
          "market_probability_pct": {
            "type": "number",
            "title": "Market Probability Pct"
          },
          "edge_pct": {
            "type": "number",
            "title": "Edge Pct"
          },
          "stats": {
            "items": {
              "$ref": "#/components/schemas/PickStat"
            },
            "type": "array",
            "title": "Stats"
          },
          "reasoning": {
            "type": "string",
            "title": "Reasoning"
          },
          "agent_key": {
            "type": "string",
            "title": "Agent Key",
            "default": "baseball-agents"
          },
          "agent_record_30d": {
            "type": "string",
            "title": "Agent Record 30D",
            "default": ""
          },
          "commence_time": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Commence Time"
          }
        },
        "type": "object",
        "required": [
          "id",
          "tier",
          "game_label",
          "market_label",
          "pick_side",
          "odds_american",
          "stake_units",
          "probability_pct",
          "market_probability_pct",
          "edge_pct",
          "reasoning"
        ],
        "title": "Pick"
      },
      "PickStat": {
        "properties": {
          "label": {
            "type": "string",
            "title": "Label"
          },
          "value": {
            "type": "string",
            "title": "Value"
          }
        },
        "type": "object",
        "required": [
          "label",
          "value"
        ],
        "title": "PickStat"
      },
      "PickTier": {
        "type": "string",
        "enum": [
          "high",
          "sweet",
          "lean"
        ],
        "title": "PickTier"
      },
      "PicksResponse": {
        "properties": {
          "picks": {
            "items": {
              "$ref": "#/components/schemas/Pick"
